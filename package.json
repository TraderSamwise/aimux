{
  "name": "aimux",
  "version": "0.1.0",
  "description": "Native CLI agent multiplexer — run AI coding tools with their native TUIs intact",
  "main": "dist/main.js",
  "bin": {
    "aimux": "./bin/aimux"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "verify": "yarn typecheck && yarn lint && yarn test",
    "prepare": "husky",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "author": "Sam <sam@tealstreet.io>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "commander": "^14.0.0",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.33.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/proper-lockfile": "^4.1.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
