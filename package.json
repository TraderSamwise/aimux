{
  "name": "aimux-cli",
  "version": "0.1.17",
  "description": "Native CLI agent multiplexer — run AI coding tools with their native TUIs intact",
  "main": "dist/main.js",
  "bin": {
    "aimux": "./bin/aimux",
    "aimux-dev": "./bin/aimux-dev"
  },
  "files": [
    "bin",
    "dist",
    "dist-ui",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "build:ui:local": "bash scripts/build-local-ui.sh",
    "dev": "tsc --watch",
    "dev:gui": "yarn dev:gui:web",
    "dev:gui:web": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:web:local",
    "dev:gui:web:relay": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:web:relay",
    "dev:gui:native": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:native:local",
    "dev:gui:native:relay": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:native:relay",
    "dev:gui:ios": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:ios:local",
    "dev:gui:ios:relay": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:ios:relay",
    "dev:gui:android": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:android:local",
    "dev:gui:android:relay": "yarn build && node bin/aimux-dev daemon ensure && yarn --cwd app dev:android:relay",
    "dev:gui:relay": "yarn dev:gui:web:relay",
    "dev:daemon": "node bin/aimux-dev daemon restart",
    "dev:daemon:openrig": "bash scripts/dev-lanes/openrig-runtime-core.sh daemon restart",
    "dev:aimux:openrig": "bash scripts/dev-lanes/openrig-runtime-core.sh",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "verify": "yarn typecheck && yarn lint && yarn test",
    "verify:codex-instructions": "bash scripts/verify-codex-developer-instructions.sh",
    "release:asset": "bash scripts/build-release-asset.sh",
    "release:patch": "yarn version --patch && git push --follow-tags",
    "release:minor": "yarn version --minor && git push --follow-tags",
    "release:major": "yarn version --major && git push --follow-tags",
    "prepack": "yarn build && yarn build:ui:local",
    "prepare": "husky",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "author": "Sam <sam@tealstreet.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TraderSamwise/aimux.git"
  },
  "homepage": "https://github.com/TraderSamwise/aimux#readme",
  "bugs": {
    "url": "https://github.com/TraderSamwise/aimux/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "simple-git": "^3.33.0",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@humanfs/core": "^0.19.1",
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/proper-lockfile": "^4.1.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.0"
  }
}
