{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "node": "24.16.0",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "testflight": {
      "node": "24.16.0",
      "environment": "production",
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "distribution": "store",
      "autoIncrement": false,
      "channel": "testflight"
    },
    "production": {
      "node": "24.16.0",
      "environment": "production",
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "android": {
        "image": "latest"
      },
      "distribution": "store",
      "autoIncrement": false,
      "channel": "production"
    }
  },
  "submit": {
    "testflight": {},
    "production": {}
  }
}
