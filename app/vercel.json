{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn export:web",
  "installCommand": "yarn install --frozen-lockfile",
  "outputDirectory": "dist",
  "devCommand": "yarn web",
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
