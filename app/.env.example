EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Connection mode:
# - unset: production builds default to relay; development builds default to local
# - local: use EXPO_PUBLIC_AIMUX_DAEMON_URL
# - relay: use EXPO_PUBLIC_AIMUX_RELAY_URL or default to wss://relay.aimux.app
# EXPO_PUBLIC_AIMUX_CONNECTION_MODE=relay

# Optional overrides
# EXPO_PUBLIC_AIMUX_DAEMON_URL=http://localhost:43191
# EXPO_PUBLIC_AIMUX_RELAY_URL=wss://relay.aimux.app
