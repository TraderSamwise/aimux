{
  "name": "aimux-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev:local": "yarn dev:web:local",
    "dev:relay": "yarn dev:web:relay",
    "dev:web:local": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=local EXPO_PUBLIC_AIMUX_DAEMON_URL=http://localhost:43190 expo start --web",
    "dev:web:relay": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=relay EXPO_PUBLIC_AIMUX_RELAY_URL=wss://relay.aimux.app expo start --web",
    "dev:native:local": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=local EXPO_PUBLIC_AIMUX_DAEMON_URL=http://127.0.0.1:43190 expo start --dev-client",
    "dev:native:relay": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=relay EXPO_PUBLIC_AIMUX_RELAY_URL=wss://relay.aimux.app expo start --dev-client",
    "dev:ios:local": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=local EXPO_PUBLIC_AIMUX_DAEMON_URL=http://127.0.0.1:43190 expo run:ios",
    "dev:ios:relay": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=relay EXPO_PUBLIC_AIMUX_RELAY_URL=wss://relay.aimux.app expo run:ios",
    "dev:android:local": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=local EXPO_PUBLIC_AIMUX_DAEMON_URL=http://10.0.2.2:43190 expo run:android",
    "dev:android:relay": "EXPO_PUBLIC_AIMUX_CONNECTION_MODE=relay EXPO_PUBLIC_AIMUX_RELAY_URL=wss://relay.aimux.app expo run:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "export:web:local": "bash ../scripts/build-local-ui.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:env": "node scripts/check-release-env.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "eas env:exec production 'eas-release build testflight' --non-interactive",
    "build:testflight": "eas env:exec production 'eas-release build testflight' --non-interactive",
    "build:production": "eas env:exec production 'eas-release build production' --non-interactive",
    "update": "eas env:exec production 'eas-release update testflight' --non-interactive",
    "update:production": "eas env:exec production 'eas-release update production' --non-interactive",
    "version:current": "eas-release current",
    "version:bump-build": "eas-release bump-build",
    "version:bump-ota": "eas-release bump-ota",
    "version:rollback": "eas-release rollback",
    "version:set": "eas-release set",
    "version:sync": "eas-release sync"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.22",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "event-source-polyfill": "^1.0.31",
    "expo": "~54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-build-properties": "^55.0.13",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "jotai": "^2.18.0",
    "jotai-optics": "^0.4.0",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4",
    "optics-ts": "^2.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "3"
  },
  "devDependencies": {
    "@tradersamwise/eas-release": "0.1.9",
    "@types/event-source-polyfill": "^1.0.5",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8",
    "vitest": "^4.0.18"
  }
}
