CLERK_SECRET_KEY=sk_test_your_key_here
# Relay secret used to pseudonymize security-event IP metadata. Set this in
# Cloudflare with `wrangler secret put SECURITY_IP_HASH_SECRET`.
# SECURITY_IP_HASH_SECRET=<random secret>

# Relay (optional — enables remote access via aimux.app)
# AIMUX_RELAY_URL points the local daemon at your deployed relay. The
# AIMUX_RELAY_TOKEN is normally produced by `aimux login` (relay-minted
# HS256, ~90d) and stored at ~/.aimux/auth.json — only set it manually
# to override the stored credential.
AIMUX_RELAY_URL=wss://relay.aimux.app
# AIMUX_RELAY_TOKEN=<minted by `aimux login` — leave unset by default>
